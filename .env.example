# Copy to `.env.local` and fill in real values. Never commit `.env.local`.
#
# ---------------------------------------------------------------------------
# Pull the SAME keys from Vercel (Production / Preview) into this machine
# ---------------------------------------------------------------------------
# One-time: link this repo to your Vercel project (from repo root):
#   npx vercel link
# Then download env vars into `.env.local` (overwrites / merges — back up first):
#   npm run env:pull-vercel
# Or explicitly:
#   npx vercel env pull .env.local --environment=production
#   npx vercel env pull .env.local --environment=preview
#   npx vercel env pull .env.local --environment=development
# You must complete browser login the first time (`npx vercel login`).
# Dashboard reference: Vercel → your project → Settings → Environment Variables
# ---------------------------------------------------------------------------

# CrustData API (v2 Person API — Bearer token)
CRUSTDATA_API_KEY=your_crustdata_api_key_here
CRUSTDATA_API_URL=https://api.crustdata.com

# OpenRouter API (AI — insights + outreach drafts)
OPENROUTER_API_KEY=your_openrouter_api_key_here
OPENROUTER_API_URL=https://openrouter.ai/api/v1

# AI Model (OpenRouter model id)
AI_MODEL=anthropic/claude-4.5-sonnet

# Supabase (profile cache + shared traces) — optional locally; required for Share
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_supabase_anon_key_here

# App (OpenRouter HTTP-Referer; optional — Vercel sets VERCEL_URL automatically in code)
NEXT_PUBLIC_APP_URL=http://localhost:3000
