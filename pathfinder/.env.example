# Copy to .env.local and fill in real values. Never commit .env.local.

# CrustData API (v2 Person API — Bearer token)
CRUSTDATA_API_KEY=your_crustdata_api_key_here
CRUSTDATA_API_URL=https://api.crustdata.com

# OpenRouter API (AI — insights + outreach drafts)
OPENROUTER_API_KEY=your_openrouter_api_key_here
OPENROUTER_API_URL=https://openrouter.ai/api/v1

# AI Model (OpenRouter model id)
AI_MODEL=anthropic/claude-4.5-sonnet

# Supabase (profile cache + shared traces)
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_supabase_anon_key_here

# App
NEXT_PUBLIC_APP_URL=http://localhost:3000
